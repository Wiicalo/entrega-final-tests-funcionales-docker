{
    "compilerOptions": {
        "module": "Node16",
        "declaration": false,
        "removeComments": false,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "ES2021",
        "sourceMap": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "incremental": true,
        "strict": true,
        "skipLibCheck": true,
        "moduleResolution": "node16",
        "esModuleInterop": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}